# Server-side Firebase Admin credentials for Vercel API functions
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_ADMIN_STORAGE_BUCKET=your_project_storage_bucket

# Worker auth — required for automated worker invocations (cron/external triggers)
# If unset, /api/worker/run-brief falls back to Firebase admin token auth only.
WORKER_SECRET=your_worker_secret_here

# Managed Browserless screenshot capture for intake artifacts
BROWSERLESS_TOKEN=your_browserless_token_here
# Optional override. Defaults to Browserless production REST base URL.
BROWSERLESS_BASE_URL=https://production-sfo.browserless.io

# Scout / Not The Rug brief feature
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# KIMI fallback — used automatically when Anthropic credit balance is exhausted
KIMI_API_KEY=your_kimi_api_key_here
NWS_USER_AGENT=NotTheRugScout/1.0 (your-email@example.com)
INSTAGRAM_ACCESS_TOKEN=your_meta_graph_access_token_here
NOT_THE_RUG_INSTAGRAM_USER_ID=your_instagram_business_account_id_here
REDDIT_CLIENT_ID=your_reddit_app_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_app_client_secret_here
REDDIT_USER_AGENT=NotTheRugScout/1.0 (your-email@example.com)

# Google PageSpeed Insights API key (free, 25k/day)
# Without key: anonymous pool (~1 req/sec). Sufficient for dev, set for prod.
# Get one at: https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=your_pagespeed_api_key_here
# Intake runner reads this as enabled unless explicitly set to 0.
PAGESPEED_ENABLED=1

# Analyzer skill fanout is off by default unless this is set in the server env.
SCOUT_ANALYZER_SKILLS_ENABLED=1
