rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: get the caller's user doc
    function callerClientId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clientId;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /clients/{clientId} {
      allow read: if request.auth != null && callerClientId() == clientId;
      allow write: if false;
    }

    match /clients/{clientId}/members/{memberId} {
      allow read: if request.auth != null && request.auth.uid == memberId;
      allow write: if false;
    }

    // Source of truth for pipeline behavior — server-owned, client read-only.
    match /client_configs/{clientId} {
      allow read: if request.auth != null && callerClientId() == clientId;
      allow write: if false;
    }

    // Normalized dashboard state — the only collection dashboard renders from.
    match /dashboard_state/{clientId} {
      allow read: if request.auth != null && callerClientId() == clientId;
      allow write: if false;
    }

    // brief_runs is admin/server-only — no direct client reads.
    match /brief_runs/{runId} {
      allow read, write: if false;
    }

    // Per-client brief_runs mirror. The run doc itself stays server-owned
    // (allow read: false), but the events subcollection is readable by the
    // signed-in user bound to that client so the dashboard terminal can
    // stream real-time pipeline progress via onSnapshot.
    match /clients/{clientId}/brief_runs/{runId} {
      allow read, write: if false;

      match /events/{eventId} {
        allow read:  if request.auth != null && callerClientId() == clientId;
        allow write: if false;
      }
    }
  }
}
